FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
COPY packages/backend/package*.json ./packages/backend/
COPY packages/frontend/package*.json ./packages/frontend/
COPY packages/shared/package*.json ./packages/shared/

RUN npm install

COPY . .

EXPOSE 3000

CMD ["npm", "run", "dev", "-w", "packages/backend"]
